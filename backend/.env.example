# Configuración del Servidor
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/loteria?retryWrites=true&w=majority

# JWT Secret (Cambiar en producción por una clave segura)
JWT_SECRET=tu_clave_secreta_super_segura_cambiala_en_produccion

# JWT Expiration
JWT_EXPIRE=30d

# Zona horaria usada para fechas, cierres y premios
APP_TIMEZONE=America/New_York

# Creacion segura del primer administrador
INITIAL_ADMIN_NAME=Administrador
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@ejemplo.com
INITIAL_ADMIN_PASSWORD=reemplaza_con_una_contrasena_de_16_caracteres
INITIAL_ADMIN_SETUP_TOKEN=reemplaza_con_un_token_aleatorio_de_32_caracteres

# Recuperacion administrativa. Mantener deshabilitada normalmente.
ALLOW_RESET_ADMIN=false

# CORS - URLs adicionales del Frontend separadas por coma
# En Railway con un solo servicio normalmente no hace falta definirlo.
FRONTEND_URL=http://localhost:3000

# Bot de resultados externo
LOTTERY_BOT_BASE_URL=https://lottery-bot-production.up.railway.app
LOTTERY_BOT_SYNC_INTERVAL_MS=300000
