{
  "name": "tby-sistemas",
  "version": "1.0.0",
  "description": "Sistema de Lotería - TBY Sistemas",
  "main": "public/electron.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "set ELECTRON_IS_DEV=1&& electron .",
    "electron-build": "electron-builder",
    "preelectron-pack": "npm run build",
    "system": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 help",
    "system:status": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 status",
    "system:install": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 install",
    "system:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 dev",
    "system:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 desktop",
    "system:auto": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 auto",
    "system:build": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 build",
    "system:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\sistema.ps1 deploy"
  },
  "keywords": [
    "loteria",
    "sistema",
    "electron",
    "react"
  ],
  "author": "TBY Sistemas",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.12.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.tbysistemas.loteria",
    "productName": "TBY Sistemas - Lotería",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
